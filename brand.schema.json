{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Speaking brand tokens",
  "type": "object",
  "properties": {
    "meta": { "type": "object" },
    "base": {
      "type": "object",
      "description": "Personal brand — applies to all decks unless overridden per client"
    },
    "clients": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "accent": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "logo": { "type": ["string", "null"] }
        }
      }
    }
  }
}
